# Copy to terraform.tfvars (gitignored) and fill in.

region      = "eu-central-1"
project     = "plugin-skill-hosting"
environment = "prod"

# ----- Networking -----
create_vpc         = true
vpc_cidr           = "10.40.0.0/16"
az_count           = 2
single_nat_gateway = true

# ----- Database -----
db_instance_class        = "db.t4g.micro"
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_multi_az              = false
db_backup_retention_days = 7
db_deletion_protection   = true

# ----- Backend -----
backend_image                 = "ghcr.io/oglimmer/plugin-skill-hosting-backend:latest"
backend_cpu                   = 512
backend_memory                = 1024
backend_ephemeral_storage_gib = 30
backend_desired_count         = 1
backend_max_count             = 1
backend_cpu_architecture      = "ARM64"

# ----- App config -----
marketplace_name = "oglimmer-marketplace"
default_license  = "MIT"
auth_mode        = "password"
anthropic_model  = "claude-sonnet-4-6"

# If auth_mode = "oidc":
# oidc_issuer_url    = "https://id.example.com/realms/example"
# oidc_client_id     = "plugin-skill-hosting"
# oidc_redirect_url  = ""  # empty -> derived from CloudFront domain
# oidc_scopes        = "openid email profile"
# oidc_client_secret = "<set me>"

# ----- Secrets (sensitive) -----
# Generate with: openssl rand -base64 48 | tr -d '\n' | head -c 64
jwt_secret = "REPLACE-WITH-A-RANDOM-STRING-AT-LEAST-32-CHARS"

# Required if you want generation features
anthropic_api_key = ""

# ----- Edge -----
cloudfront_price_class = "PriceClass_100"
enable_waf             = true

# ----- Observability -----
log_retention_days = 30

# Optional — email subscribed to baseline CloudWatch alarms (ECS health,
# ALB 5xx, RDS CPU/storage). Leave empty to skip the SNS topic; alarms
# still fire in the CloudWatch console.
alarm_email = ""
