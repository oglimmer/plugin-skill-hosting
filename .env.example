PUBLIC_BASE_URL=http://localhost:8080
MARKETPLACE_NAME=oglimmer-marketplace

# Enterprise team rollout (presentation only — changes no auth or capability).
# When true, the "connect" UI leads with how an admin distributes the
# marketplace / plugins / MCP server via Claude Code managed settings, and the
# per-user personal-token setup moves behind an "expert mode" toggle.
# ENTERPRISE_MODE=true

POSTGRES_USER=marketplace
POSTGRES_PASSWORD=marketplace
POSTGRES_DB=marketplace

DATABASE_URL=postgres://marketplace:marketplace@db:5432/marketplace?sslmode=disable
# Signs session JWTs. MUST be unique and at least 32 chars — generate with
# `openssl rand -hex 32`. The backend refuses to start with the in-repo default
# or anything shorter than 32 chars unless ALLOW_INSECURE_JWT_SECRET=true.
JWT_SECRET=change-me-in-production-please-use-32-chars-min
# Local-dev escape hatch ONLY: permit an insecure/short JWT_SECRET. Never set
# this in production.
# ALLOW_INSECURE_JWT_SECRET=true
# Key (64 hex chars = 32 bytes; `openssl rand -hex 32`) used to encrypt API
# tokens at rest. Optional: if unset it is derived from JWT_SECRET. Set a
# dedicated key to decouple token display from JWT_SECRET rotation. Token
# *authentication* uses a separate hash and is unaffected by this key either way.
# API_TOKEN_ENC_KEY=
# CORS allowlist (comma-separated origins; "*" allows any). Leave unset to derive
# from PUBLIC_BASE_URL — "*" on localhost, locked to the app origin otherwise.
# Set explicitly if a cross-origin browser client must call the API.
# CORS_ALLOWED_ORIGINS=https://marketplace.example.com
LISTEN_ADDR=:8080
DATA_DIR=/data

# Sign-in mode: "password" (default) or "oidc".
#
# WARNING: AUTH_MODE=password is for LOCAL DEVELOPMENT ONLY. It has no login
# rate limiting / brute-force protection and exposes open self-service
# registration. ALL PRODUCTION DEPLOYMENTS MUST SET AUTH_MODE=oidc and provide
# the OIDC_* values below. See README.md ("Authentication") for details.
# AUTH_MODE=oidc

# Claude API — required for the skill validator and the scheduled security audit.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Scheduled skill security audit. Enabled by default; a no-op until
# ANTHROPIC_API_KEY is set. When active, a background job re-evaluates every
# skill for malicious/harmful behavior on the given interval, stores the
# verdict, and emails AUDIT_ALERT_EMAILS when a skill's risk score (0-100)
# reaches AUDIT_ALERT_THRESHOLD. Set AUDIT_ENABLED=false to turn it off.
# AUDIT_ENABLED=false
# AUDIT_INTERVAL=24h            # Go duration: 24h (daily), 168h (weekly), etc.
# AUDIT_ALERT_THRESHOLD=70      # 0-100; alert when risk score >= this
# AUDIT_ALERT_EMAILS=security@example.com,ops@example.com

# SMTP for outbound alert email. Leave SMTP_HOST empty to disable email — the
# audit job then logs alerts instead of sending them.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=change-me
# SMTP_FROM=marketplace-audit@example.com
# SMTP_USE_TLS=true             # STARTTLS upgrade after connecting
